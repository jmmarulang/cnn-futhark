# Note that we are using pandoc-include filter:
# https://github.com/DCsunset/pandoc-include
# (also available via nix) because hoas.agda requires
# --backtracking to search through instances, but
# if we enable it globally, it hangs.  Therefore,
# we separate hoas.lagda.md into a separate module
# that includes present.lagda.md. However, hoas.md
# includes the slides generated by hoas.md.


MY_CSS := my.css
AGDA   := agda

all : present.html

build/%.md: %.lagda.md
	$(AGDA) --html-highlight=auto \
	        --html --html-dir=build $<

# Resulting html output has to live in the _build
# directory so that the links to modules resolve
# appropriately.
.PRECIOUS: build/%.html build/hoas.md build/present.md
build/%.html: build/%.md build/hoas.md build/reveal.js
	pandoc -t revealjs \
				 --filter=pandoc-include \
         --slide-level=2 \
				 -V revealjs-url:$(PWD)/build/reveal.js \
         --mathjax \
				 --metadata slideNumber="\"c/t\"" \
	       --css=$(MY_CSS) \
         --css=Agda.css -s $< -o $@

				 # --self-contained \

%.html: build/%.html
	$(RM) $@
	ln -s $< $@

clean:
	$(RM) -r present.html build/*.html build/*.md 
